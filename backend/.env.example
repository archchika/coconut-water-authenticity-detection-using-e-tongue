# Phase 5.9 / 6.8 — Environment template for Django backend (production).
# Copy to .env and fill in values. Do not commit .env — no secrets in repo.

# Required in production (config.settings.production)
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed hosts (e.g. api.example.com,www.example.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Phase 5.4) — use either DB_* vars or DATABASE_URL
DB_NAME=etongue
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
# DATABASE_URL=postgres://user:password@host:5432/etongue

# Optional: CORS origins for frontend (comma-separated)
# CORS_ALLOWED_ORIGINS=https://www.example.com,https://admin.example.com

# Optional: static files directory (default: backend/staticfiles)
# STATIC_ROOT=/var/www/backend/staticfiles

# Phase 6.8 — Security / rate limiting (optional overrides)
# SECURE_SSL_REDIRECT=true
# UPLOAD_THROTTLE_RATE=60/hour

# Optional: use in development with python-dotenv (load from .env)
# DJANGO_SETTINGS_MODULE=config.settings.production
